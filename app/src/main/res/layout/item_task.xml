<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <!-- Card background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_task_card_new"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:elevation="2dp">

        <!-- Checkbox circle 24dp -->
        <ImageView
            android:id="@+id/iv_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="完成"
            android:src="@drawable/ic_check_circle_outline" />

        <!-- Task body -->
        <LinearLayout
            android:id="@+id/t_body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:minWidth="0dp">

            <TextView
                android:id="@+id/tv_task_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/md_on_surface"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Category badge pill -->
                <TextView
                    android:id="@+id/tv_category_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_category_badge"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold" />

                <!-- Time range -->
                <TextView
                    android:id="@+id/tv_task_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right side: time + coin reward -->
        <LinearLayout
            android:id="@+id/layout_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="end"
            android:orientation="vertical">

            <!-- Start time -->
            <TextView
                android:id="@+id/tv_start_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Coin reward -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Mini coin 12dp -->
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="金币"
                    android:src="@drawable/bg_mini_coin_chip" />

                <TextView
                    android:id="@+id/tv_coins_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coin_gold_dark"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Left color bar 4dp (overlaid on card) -->
    <View
        android:id="@+id/view_cat_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/category_work" />

</FrameLayout>
