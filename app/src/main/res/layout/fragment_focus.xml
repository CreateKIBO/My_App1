<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- Sub-tab bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/btn_tab_pomodoro"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="🍅 番茄钟"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_tab_selected" />

            <TextView
                android:id="@+id/btn_tab_curve"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="📈 遗忘曲线"
                android:textSize="14sp"
                android:textColor="@color/md_on_surface_variant"
                android:background="@drawable/bg_tab_unselected" />
        </LinearLayout>

        <!-- Pomodoro content -->
        <LinearLayout
            android:id="@+id/layout_pomodoro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Timer circle area -->
            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp">

                <com.example.myapplication.ui.widget.TimerRingView
                    android:id="@+id/timer_ring"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_timer_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25:00"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_on_surface" />

                    <TextView
                        android:id="@+id/tv_timer_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="专注时间"
                        android:textSize="12sp"
                        android:textColor="@color/md_on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Task name input -->
            <EditText
                android:id="@+id/et_task_name"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="20dp"
                android:hint="正在专注什么？（可选）"
                android:textSize="14sp"
                android:textColorHint="@color/md_on_surface_variant"
                android:textColor="@color/md_on_surface"
                android:background="@drawable/bg_input_rounded"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:maxLines="1" />

            <!-- Duration selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/btn_duration_15"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="15分"
                    android:textSize="12sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/md_on_surface_variant"
                    android:background="@drawable/bg_pill_unselected" />

                <TextView
                    android:id="@+id/btn_duration_25"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="25分"
                    android:textSize="12sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_pill_selected" />

                <TextView
                    android:id="@+id/btn_duration_45"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="45分"
                    android:textSize="12sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/md_on_surface_variant"
                    android:background="@drawable/bg_pill_unselected" />

                <TextView
                    android:id="@+id/btn_duration_60"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="60分"
                    android:textSize="12sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/md_on_surface_variant"
                    android:background="@drawable/bg_pill_unselected" />
            </LinearLayout>

            <!-- Control buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <ImageView
                    android:id="@+id/btn_reset"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_reset"
                    android:contentDescription="重置"
                    android:padding="10dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_pause"
                    android:layout_width="160dp"
                    android:layout_height="48dp"
                    android:text="开始专注"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    app:backgroundTint="@color/md_primary" />

                <ImageView
                    android:id="@+id/btn_skip"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_skip"
                    android:contentDescription="跳过"
                    android:padding="10dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Today stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="28dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tv_today_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="今日番茄"
                        android:textSize="12sp"
                        android:textColor="@color/md_on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tv_today_minutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/xp_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="专注分钟"
                        android:textSize="12sp"
                        android:textColor="@color/md_on_surface_variant"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Forgetting curve content -->
        <LinearLayout
            android:id="@+id/layout_curve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Curve visualization -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <com.example.myapplication.ui.widget.ForgettingCurveView
                    android:id="@+id/curve_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp" />
            </androidx.cardview.widget.CardView>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_active_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="学习中"
                        android:textSize="11sp"
                        android:textColor="@color/md_on_surface_variant" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="12dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:id="@+id/tv_due_today_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="今日待复习"
                        android:textSize="11sp"
                        android:textColor="@color/md_on_surface_variant" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tv_mastered_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/xp_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已掌握"
                        android:textSize="11sp"
                        android:textColor="@color/md_on_surface_variant" />
                </LinearLayout>
            </LinearLayout>

            <!-- Today's reviews section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日复习"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_no_reviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今天没有复习任务 🎉"
                android:textSize="14sp"
                android:textColor="@color/md_on_surface_variant"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_today_reviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:nestedScrollingEnabled="false" />

            <!-- All learning items section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="学习项目"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_no_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="在添加学习任务时开启「加入复习计划」\n即可自动生成复习提醒"
                android:textSize="13sp"
                android:textColor="@color/md_on_surface_variant"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_curve_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
