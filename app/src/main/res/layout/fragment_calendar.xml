<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="100dp">

        <!-- ── Month navigation row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btn_prev_month"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_month_nav_btn"
                android:contentDescription="上个月"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/md_on_surface" />

            <TextView
                android:id="@+id/tv_month_year"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/md_on_surface"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_today"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="12dp"
                    android:text="@string/calendar_today"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    app:cornerRadius="9999dp" />

                <ImageView
                    android:id="@+id/btn_next_month"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_month_nav_btn"
                    android:contentDescription="下个月"
                    android:padding="10dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/md_on_surface" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Streak banner ── -->
        <LinearLayout
            android:id="@+id/streak_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_streak_banner"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/streak_fire_emoji"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_streak_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.02"
                    android:textColor="@color/streak_orange"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_streak_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Calendar card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp">

                <!-- Weekday headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="日"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/streak_orange"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="一"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="二"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="三"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="四"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="五"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/md_on_surface_variant"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="六"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/streak_orange"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06" />
                </LinearLayout>

                <!-- Calendar grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_calendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Legend row ── -->
        <LinearLayout
            android:id="@+id/layout_legend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginEnd="16dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_legend_dot_work"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="工作"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginEnd="16dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_legend_dot_study"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="学习"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginEnd="16dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_legend_dot_exercise"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="运动"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginEnd="16dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_legend_dot_personal"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个人"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_legend_dot_streak"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连续"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Day detail panel ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Detail header: date label + completion badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_detail_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.01"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/md_on_surface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_partial"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Task list for selected date -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_detail_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="true"
                    android:clipToPadding="false" />

                <!-- Empty state for selected date -->
                <LinearLayout
                    android:id="@+id/layout_detail_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="这天没有任务"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/md_on_surface_variant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
