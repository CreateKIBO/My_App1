<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Pixel sun: center circle + 8 rays, pixel-grid style -->
    <!-- Center area: 54,54 center. Icon content in 24-84 range. -->
    <!-- Each "pixel" is a 4x4 unit square -->

    <!-- Sun center circle (pixel blocks forming a circle) -->
    <!-- Row 1 of circle (y=46): x=46-62 -->
    <path android:fillColor="#FFD54F"
          android:pathData="M50,46h8v4h-8z M46,50h16v4h-16z M46,54h16v4h-16z M46,58h16v4h-16z M50,62h8v4h-8z" />

    <!-- Sun center highlight -->
    <path android:fillColor="#FFECB3"
          android:pathData="M50,50h8v4h-8z M50,54h4v4h-4z" />

    <!-- Rays (pixel blocks) - 8 directions -->

    <!-- Top ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M54,34h4v8h-4z M52,38h8v4h-8z" />

    <!-- Bottom ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M54,66h4v8h-4z M52,70h8v4h-8z" />

    <!-- Left ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M34,54h8v4h-8z M38,52h4v8h-4z" />

    <!-- Right ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M66,54h8v4h-8z M70,52h4v8h-4z" />

    <!-- Top-left ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M38,38h4v4h-4z M42,42h4v4h-4z" />

    <!-- Top-right ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M66,38h4v4h-4z M62,42h4v4h-4z" />

    <!-- Bottom-left ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M38,66h4v4h-4z M42,62h4v4h-4z" />

    <!-- Bottom-right ray -->
    <path android:fillColor="#FFD54F"
          android:pathData="M66,66h4v4h-4z M62,62h4v4h-4z" />

    <!-- Pixel "日" character overlay (small, in center of sun) -->
    <!-- Simplified pixel 日: outer box + inner horizontal line -->
    <path android:fillColor="#E65100"
          android:pathData="M48,48h12v12h-12z" />
    <path android:fillColor="#FFD54F"
          android:pathData="M50,50h8v4h-8z M50,56h8v2h-8z" />
    <!-- Inner gap line -->
    <path android:fillColor="#FFD54F"
          android:pathData="M48,54h12v2h-12z" />

</vector>